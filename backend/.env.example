# Server Configuration
PORT=5000

# Database
MONGO_URI=mongodb://localhost:27017/velora

# Authentication
JWT_SECRET=somascience_jwt_secret_token_key_987654321

# Razorpay Payment Gateway
# Get these from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=YYYYYYYYYYYYYYYYYY

# Razorpay Webhook (Optional but Recommended)
# Get this from: https://dashboard.razorpay.com/app/webhooks
RAZORPAY_WEBHOOK_SECRET=whsec_ZZZZZZZZZZZZZZ

# Email Configuration (Optional - for order confirmation emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password

# Notes:
# - Without Razorpay credentials, system runs in simulated mode
# - For Gmail, enable 2FA and generate app password: https://myaccount.google.com/apppasswords
# - Webhook URL format: https://yourdomain.com/api/payments/webhook
